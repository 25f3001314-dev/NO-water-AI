# User Authentication Credentials (separate by semicolon for multiple users)
# Format: username:password,company,role
VALID_USERS=admin:admin123,Jal-Drishti,Officer;techuser:tech456,TechCorp,Engineer

# API Keys for Frontend & Backend
# Get these from respective services:
# OpenWeatherMap: https://openweathermap.org/api
# Google Gemini: https://ai.google.dev/
OPENWEATHER_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here

# Frontend environment variables (injected at build time)
REACT_APP_OPENWEATHER_API_KEY=your_key_here
REACT_APP_GEMINI_API_KEY=your_key_here
REACT_APP_API_URL=http://localhost:8000

# Flask Configuration
FLASK_ENV=production
FLASK_SECRET_KEY=your_secret_key_change_in_production
